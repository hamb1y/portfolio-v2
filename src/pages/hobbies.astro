---
import Layout from "../components/Layout.astro";
import Card from "../components/Card.astro";
import { getCollection } from "astro:content";
import { Brain, Cpu, Gamepad2, Code2, BookOpen, Recycle } from "@lucide/astro";

const hobbies = await getCollection("hobbies");

const iconMap: Record<string, any> = {
  brain: Brain,
  cpu: Cpu,
  gamepad2: Gamepad2,
  code2: Code2,
  bookopen: BookOpen,
  recycle: Recycle,
};
---

<Layout title="Hobbies">
  <div class="min-h-screen pt-32">
    <div class="container">
      <h1 class="text-5xl font-bold mb-12">Hobbies & Interests</h1>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {
          hobbies.map((hobby) => {
            const { icon, name, description } = hobby.data;
            const HobbyIcon = iconMap[icon] ?? BookOpen;
            return (
              <Card variant="default" className="hover-scale transition-transform duration-300">
                <div class="p-6 text-center">
                  <div class="hobby-icon-wrap mb-4">
                    <HobbyIcon class="hobby-icon" />
                  </div>
                  <h3 class="text-2xl font-bold mb-2">{name}</h3>
                  <p class="text-text-muted">{description}</p>
                </div>
              </Card>
            );
          })
        }
      </div>
    </div>
  </div>

  <style>
    .hobby-icon-wrap {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 3.5rem;
      height: 3.5rem;
      margin-inline: auto;
      border-radius: 9999px;
      background: color-mix(in srgb, var(--color-accent) 14%, transparent);
      color: var(--color-accent);
    }

    :global(.hobby-icon) {
      width: 1.8rem;
      height: 1.8rem;
    }
  </style>
</Layout>

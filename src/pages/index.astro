---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import ProjectGrid from "../components/ProjectGrid.astro";
import ProductGrid from "../components/ProductGrid.astro";
import SkillGrid from "../components/SkillGrid.astro";
import BlogSection from "../components/BlogSection.astro";
import AchievementsGrid from "../components/AchievementsGrid.astro";
import HobbiesGrid from "../components/HobbiesGrid.astro";
import { getCollection } from "astro:content";

const siteData = await getCollection("site");
const site = siteData[0]?.data;
---

<Layout>
  <div class="min-h-screen">
    <!-- Hero Section -->
    <section class="section hero-section">
      <div class="container">
        <Hero />
      </div>
    </section>

    <div class="section-stack">
      <!-- Featured Products -->
      <ProductGrid />

      <!-- Featured Projects -->
      <ProjectGrid />

      <!-- Blog Posts -->
      <BlogSection />

      <!-- Skills -->
      <SkillGrid />

      <!-- Achievements -->
      <AchievementsGrid />

      <!-- Hobbies -->
      <HobbiesGrid />
    </div>

    <!-- Footer -->
    <footer class="section footer-section">
      <div class="container footer-inner">
        <p class="text-text-muted text-sm">
          Built with Astro &amp; Svelte &mdash; {
            new Date().getFullYear()
          }
        </p>
        <div class="footer-right">
          {
            site?.socials.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                class="footer-link"
              >
                {social.name}
              </a>
            ))
          }
          <a href="#" class="footer-link footer-top" aria-label="Back to top">
            ↑ Top
          </a>
        </div>
      </div>
    </footer>
  </div>
</Layout>

<style>
  .hero-section {
    padding-top: 9rem;
    padding-bottom: 2rem;
  }

  .section-stack {
    display: flex;
    flex-direction: column;
    gap: clamp(0.5rem, 2vw, 1.25rem);
  }

  .section-stack :global(.section) {
    padding-top: clamp(3.5rem, 5vw, 5rem);
    padding-bottom: clamp(3.5rem, 5vw, 5rem);
  }

  .footer-section {
    padding-top: 2rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .footer-right {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .footer-link {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.55);
    transition: color 0.2s, transform 0.2s;
    text-decoration: none;
  }

  .footer-link:hover {
    color: var(--color-text);
    transform: translateY(-1px);
  }
</style>

---
import Layout from "../components/Layout.astro";
import Card from "../components/Card.astro";
import { getCollection } from "astro:content";

const blogPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((post) => ({
    id: post.id,
    slug: post.id,
    title: post.data.title,
    description: post.data.description,
    date: post.data.date,
    readTime: post.data.readTime,
    tags: post.data.tags,
    image: post.data.image,
  }));
---

<Layout title="Blog">
  <div class="min-h-screen pt-32">
    <div class="container">
      <h1 class="text-5xl font-bold mb-12">Blog</h1>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {blogPosts.map((post) => {
          const { id, slug, title, description, date, readTime, tags, image } = post;
          const imageUrl = typeof image === 'object' ? image?.url : image;
          return (
            <Card variant="default" className="h-full hover-scale transition-transform duration-300">
              <div class="flex flex-col h-full">
                {imageUrl && (
                  <img
                    src={imageUrl}
                    alt={title}
                    class="w-full h-48 object-cover rounded-t-lg"
                  />
                )}
                <div class="p-6 flex-grow">
                  <h3 class="text-2xl font-bold mb-3">
                    <a href={`/blog/${slug}`} class="hover:underline">{title}</a>
                  </h3>
                  <p class="text-text-muted mb-4">{description}</p>

                  {tags && tags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mb-4">
                      {tags.map((tag) => (
                        <span class="badge text-xs">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
                <div class="px-6 pb-6 pt-4 border-t border-border flex justify-between text-sm text-text-muted">
                  <span>{new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                  {readTime && <span>{readTime} read</span>}
                </div>
              </div>
            </Card>
          );
        })}
      </div>
    </div>
  </div>
</Layout>
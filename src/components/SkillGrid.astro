---
import SkillCard from "./SkillCard.astro";
import { getCollection } from "astro:content";

const skills = await getCollection("skills");
---

<section id="skills" class="section">
  <div class="container">
    <div class="section-heading">
      <h2 class="section-title">Skills & Expertise</h2>
      <p class="section-subtitle">A snapshot of the tools and disciplines I lean on most often.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6">
      {
        skills.map((skill) => {
          const { icon, name, description, level } = skill.data;
          return <SkillCard skill={{ icon, name, description, level }} animate={true} />;
        })
      }
    </div>
  </div>
</section>

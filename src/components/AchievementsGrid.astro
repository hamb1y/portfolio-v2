---
import Card from "./Card.astro";
import { getCollection } from "astro:content";

const achievements = await getCollection("achievements");
const sortedAchievements = [...achievements].sort(
  (a, b) => (b.data.priority || 0) - (a.data.priority || 0),
);
---

<section id="achievements" class="section">
  <div class="container">
    <h2 class="section-title">Achievements & Certifications</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        sortedAchievements.map((achievement) => {
          const { type, title, description, date, image } = achievement.data;
          return (
            <Card
              variant="default"
              className="hover-scale transition-transform duration-300 h-full"
            >
              <div class="p-6 h-full flex flex-col">
                <div class="flex flex-col gap-4 h-full">
                  {image && (
                    <img
                      src={image}
                      alt={title}
                      class="w-full h-48 rounded-lg object-cover mb-2 cursor-pointer hover:scale-[1.02] transition-transform duration-300 achievement-img"
                      data-image={image}
                      data-alt={title}
                    />
                  )}
                  <div class="flex-1 flex flex-col">
                    <div class="flex flex-col gap-2 mb-2">
                      <h3 class="text-xl font-bold">{title}</h3>
                      <div class="flex gap-2 items-center flex-wrap">
                        {date && (
                          <span class="badge">
                            {new Date(date).getFullYear()}
                          </span>
                        )}
                        {type && <span class="badge">{type}</span>}
                      </div>
                    </div>

                    <p class="text-text-muted mt-2 flex-grow text-sm">
                      {description}
                    </p>
                  </div>
                </div>
              </div>
            </Card>
          );
        })
      }
    </div>
  </div>
</section>

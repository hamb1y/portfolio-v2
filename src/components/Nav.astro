---
import { getCollection } from "astro:content";

const siteData = await getCollection("site");
const site = siteData[0]?.data || { siteTitle: "Portfolio", name: "Your Name" };

const navItems = [
  { label: "Home", href: "/" },
  { label: "Skills", href: "/skills" },
  { label: "Achievements", href: "/achievements" },
  { label: "Projects", href: "/projects" },
  { label: "Hobbies", href: "/hobbies" },
  { label: "Products", href: "/products" },
];

const currentPath = Astro.url.pathname;
function isActive(href: string) {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">{site.name}</a>

    <!-- Desktop links -->
    <div class="nav-desktop">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class={`nav-link${isActive(item.href) ? " nav-link--active" : ""}`}
          >
            {item.label}
          </a>
        ))
      }
    </div>

    <!-- Hamburger button (mobile only) -->
    <button
      id="hamburger"
      class="hamburger"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <svg
        id="icon-open"
        width="24"
        height="24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"></path></svg
      >
      <svg
        id="icon-close"
        width="24"
        height="24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
        style="display:none"><path d="M6 18L18 6M6 6l12 12"></path></svg
      >
    </button>
  </div>

  <!-- Mobile dropdown -->
  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    {
      navItems.map((item) => (
        <a
          href={item.href}
          class={`mobile-link${isActive(item.href) ? " mobile-link--active" : ""}`}
        >
          {item.label}
        </a>
      ))
    }
  </div>
</nav>

<script>
  function initNav() {
    const btn = document.getElementById(
      "hamburger",
    ) as HTMLButtonElement | null;
    const menu = document.getElementById("mobile-menu") as HTMLElement | null;
    const iconOpen = document.getElementById("icon-open") as HTMLElement | null;
    const iconClose = document.getElementById(
      "icon-close",
    ) as HTMLElement | null;
    if (!btn || !menu || !iconOpen || !iconClose) return;

    let open = false;

    // Strip old listeners by replacing the button with a clone
    const fresh = btn.cloneNode(true) as HTMLButtonElement;
    btn.parentNode?.replaceChild(fresh, btn);

    function setOpen(next: boolean) {
      open = next;
      menu!.style.display = next ? "flex" : "none";
      iconOpen!.style.display = next ? "none" : "block";
      iconClose!.style.display = next ? "block" : "none";
      fresh.setAttribute("aria-expanded", String(next));
      menu!.setAttribute("aria-hidden", String(!next));
    }

    fresh.addEventListener("click", () => setOpen(!open));

    // Close when a mobile link is clicked
    menu.querySelectorAll(".mobile-link").forEach((link) => {
      link.addEventListener("click", () => setOpen(false));
    });

    // Close on outside click
    document.addEventListener("click", (e) => {
      if (
        open &&
        !fresh.contains(e.target as Node) &&
        !menu.contains(e.target as Node)
      ) {
        setOpen(false);
      }
    });

    // Close on Escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && open) setOpen(false);
    });
  }

  initNav();
  document.addEventListener("astro:page-load", initNav);
</script>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: #000;
    border-bottom: 1px solid #333;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-weight: 700;
    font-size: 1.1rem;
    color: #fff;
    text-decoration: none;
  }

  /* ── Desktop links ──────────────────── */
  .nav-desktop {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .nav-link {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s;
  }
  .nav-link:hover,
  .nav-link--active {
    color: #fff;
  }
  .nav-link--active {
    border-bottom: 2px solid #fff;
    padding-bottom: 2px;
  }

  /* ── Hamburger ──────────────────────── */
  .hamburger {
    display: none;
    background: transparent;
    border: 1px solid #555;
    color: #fff;
    padding: 0.4rem;
    cursor: pointer;
    border-radius: 4px;
    line-height: 0;
  }

  /* ── Mobile menu (hidden by default) ── */
  .mobile-menu {
    display: none; /* JS controls this */
    flex-direction: column;
    background: #000;
    border-top: 1px solid #333;
    padding: 1rem 1.5rem 1.5rem;
    gap: 0;
  }

  .mobile-link {
    display: block;
    padding: 0.85rem 0;
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    font-size: 1.05rem;
    border-bottom: 1px solid #222;
    transition: color 0.2s;
  }
  .mobile-link:last-child {
    border-bottom: none;
  }
  .mobile-link:hover {
    color: #fff;
  }

  /* ── Responsive breakpoint ─────────── */
  @media (max-width: 767px) {
    .nav-desktop {
      display: none;
    }
    .hamburger {
      display: block;
    }
  }
</style>

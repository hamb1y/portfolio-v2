---
import Nav from "./Nav.astro";
import { ClientRouter } from "astro:transitions";
import { getCollection } from "astro:content";
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
}

const siteData = await getCollection("site");
const site = siteData[0]?.data;

const { title: titleProp, description } = Astro.props;
const pageTitle = titleProp
  ? `${titleProp} — ${site?.name ?? "Portfolio"}`
  : (site?.siteTitle ?? "Portfolio");
const pageDesc = description ?? site?.siteDesc ?? "Personal portfolio";
const siteUrl = "https://rishimalnad.dev";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDesc} />
    <title>{pageTitle}</title>
    <ClientRouter />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content={site?.name ?? "Portfolio"} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />

    <!-- Font -->
    <link
      rel="preload"
      href="/fonts/GoogleSans.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>

  <body>
    <!-- Starfield Background -->
    <canvas
      id="starfield-canvas"
      transition:persist
      style="position: fixed; inset: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none;"
    ></canvas>

    <!-- Navigation -->
    <Nav />

    <!-- Main Content -->
    <main class="z-10 relative">
      <slot />
    </main>

    <!-- Global Lightbox -->
    <div
      id="achievement-lightbox"
      class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 cursor-zoom-out p-4 sm:p-8"
    >
      <img
        id="lightbox-img"
        src=""
        alt=""
        class="object-contain rounded-lg scale-95 transition-transform duration-300 shadow-2xl bg-black/50"
        style="width: auto; height: auto; max-width: 90vw; max-height: 90vh;"
      />
    </div>

    <script>
      import { Starfield } from "../lib/starfield.ts";

      // ── Starfield ──────────────────────────────────────────────
      let animFrame: number | null = null;

      function initStarfield() {
        if (animFrame !== null) return; // canvas persists, already running
        const canvas = document.getElementById(
          "starfield-canvas",
        ) as HTMLCanvasElement | null;
        if (!canvas) return;
        let sf: Starfield;
        try {
          sf = new Starfield(canvas, { starCount: 180, parallaxIntensity: 0.35 });
        } catch {
          return;
        }
        const loop = () => {
          sf.draw();
          animFrame = requestAnimationFrame(loop);
        };
        loop();
        window.addEventListener("mousemove", (e) =>
          sf.updateMouse(
            e.clientX / window.innerWidth,
            e.clientY / window.innerHeight,
          ),
        );
        window.addEventListener("resize", () => sf.resize());
      }

      initStarfield();
      document.addEventListener("astro:page-load", initStarfield);

      // ── Scroll reveal ──────────────────────────────────────────
      function setupReveal() {
        document.documentElement.classList.add("js");
        const obs = new IntersectionObserver(
          (entries) =>
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("revealed");
                obs.unobserve(e.target);
              }
            }),
          { threshold: 0.06, rootMargin: "0px 0px -40px 0px" },
        );
        document
          .querySelectorAll("section.section")
          .forEach((el) => obs.observe(el));
      }

      setupReveal();
      document.addEventListener("astro:page-load", setupReveal);

      // ── Lightbox ───────────────────────────────────────────────
      function setupLightbox() {
        (window as any).__lightboxAbort?.();
        const controller = new AbortController();
        (window as any).__lightboxAbort = () => controller.abort();
        const { signal } = controller;

        const images = document.querySelectorAll(".achievement-img");
        const lightbox = document.getElementById("achievement-lightbox");
        const lightboxImg = document.getElementById(
          "lightbox-img",
        ) as HTMLImageElement | null;
        const mainContent = document.querySelector("main");
        if (!lightbox || !lightboxImg) return;

        images.forEach((img) => {
          img.addEventListener(
            "click",
            () => {
              const src = img.getAttribute("data-image");
              const alt = img.getAttribute("data-alt");
              if (!src) return;
              lightboxImg.src = src;
              lightboxImg.alt = alt ?? "";
              lightbox.classList.remove("pointer-events-none", "opacity-0");
              lightbox.classList.add("opacity-100");
              lightboxImg.classList.replace("scale-95", "scale-100");
              if (mainContent) {
                mainContent.style.filter =
                  "blur(5px) brightness(0.4) grayscale(0.5)";
                mainContent.style.transform = "scale(0.97)";
                mainContent.style.transition =
                  "all 0.4s cubic-bezier(0.16, 1, 0.3, 1)";
              }
              document.body.style.overflow = "hidden";
            },
            { signal },
          );
        });

        lightbox.addEventListener(
          "click",
          () => {
            lightbox.classList.replace("opacity-100", "opacity-0");
            lightbox.classList.add("pointer-events-none");
            lightboxImg.classList.replace("scale-100", "scale-95");
            if (mainContent) {
              mainContent.style.filter = "";
              mainContent.style.transform = "";
            }
            document.body.style.overflow = "";
            setTimeout(() => {
              lightboxImg.src = "";
              lightboxImg.alt = "";
            }, 300);
          },
          { signal },
        );
      }

      setupLightbox();
      document.addEventListener("astro:page-load", setupLightbox);
    </script>
  </body>
</html>
